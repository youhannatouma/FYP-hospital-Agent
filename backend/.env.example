# ===== ENVIRONMENT & SECURITY =====
# Set to: development | staging | production
# Production requires HTTPS and additional security checks
ENVIRONMENT=development
DEBUG_MODE=true

# ===== DATABASE =====
# Fallback DB_* settings when DATABASE_URL is not set.
# Host/local runtime path. Docker Compose overrides these to db:5432.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=FYP
DB_USER=postgres
DB_PASSWORD=

# Complete database URL (takes precedence over DB_* variables)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/FYP

# ===== JWT & AUTHENTICATION =====
# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace_with_secure_random_secret
ALGORITHM=HS256

# PostgreSQL password for initial setup
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# Clerk OAuth configuration
CLERK_SECRET_KEY=
CLERK_JWKS_URL=https://api.clerk.com/.well-known/jwks.json

# ===== CORS CONFIGURATION =====
# Development: localhost (default)
# Production: Set explicitly to your domain(s)
# Format: https://example.com,https://api.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== API KEYS =====
GOOGLE_API_KEY=
# Optional alias; GOOGLE_API_KEY takes precedence when both are set.
GEMINI_API_KEY=
GEMINI_REQUEST_TIMEOUT_SECONDS=20
GEMINI_RETRIES=1

# ===== TELEMETRY & MONITORING =====
TELEMETRY_ENABLED=false
TELEMETRY_SAMPLE_RATE=0.10
TELEMETRY_PII_MASKING=true
TELEMETRY_SINK=stdout

# ===== FEATURE FLAGS =====
# Specialized doctor endpoint rollout and fallback policy
# Values: off | shadow | canary | on
SPECIALIZED_DOCTOR_ROLLOUT_MODE=shadow
SPECIALIZED_DOCTOR_CANARY_PERCENT=5
SPECIALIZED_DOCTOR_AUTO_FALLBACK=true
SPECIALIZED_DOCTOR_FALLBACK_REASON_LOGGING=true

# ===== AUDIT & LOGGING =====
# Enable audit logging for compliance
AUDIT_LOG_ENABLED=true
# Retention period in days (0 = indefinite)
AUDIT_LOG_RETENTION_DAYS=90

# ===== FILE UPLOAD =====
# Maximum file upload size in MB
MAX_FILE_UPLOAD_SIZE_MB=10
# Allowed file extensions (comma-separated)
ALLOWED_FILE_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

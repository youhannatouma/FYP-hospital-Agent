DB_HOST=localhost
DB_PORT=5432
DB_NAME=FYP
DB_USER=postgres
DB_PASSWORD=

SECRET_KEY=
ALGORITHM=HS256
POSTGRES_PASSWORD=
CLERK_SECRET_KEY=
CORS_ORIGINS=

# Environment Configuration Example
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/FYP

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT Settings
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Encryption at Rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required for production, optional for development
ENCRYPTION_KEY=

# ============================================================================
# REDIS (Distributed Rate Limiting)
# ============================================================================
# Enable Redis for production deployments
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# For Docker Compose:
# REDIS_URL=redis://redis:6379/0

# ============================================================================
# PASSWORD POLICY
# ============================================================================
# Minimum password length (NIST recommends 12)
MIN_PASSWORD_LENGTH=12

# Maximum password length
MAX_PASSWORD_LENGTH=128

# Password expiration (days; 0 = no expiration)
PASSWORD_EXPIRATION_DAYS=0

# Number of previous passwords to track for reuse prevention
PASSWORD_HISTORY_COUNT=5

# ============================================================================
# AUDIT LOGGING
# ============================================================================
# Enable comprehensive audit logging
AUDIT_LOG_ENABLED=true

# Audit log retention period (days)
AUDIT_LOG_RETENTION_DAYS=365

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================
# Development (allows localhost)
# CORS_ORIGINS will default to: http://localhost:3000,http://127.0.0.1:3000

# Production (required in production, no wildcards!)
# CORS_ORIGINS=https://yourhospital.com,https://api.yourhospital.com

# ============================================================================
# ENVIRONMENT
# ============================================================================
# development | staging | production
ENVIRONMENT=development
DEBUG_MODE=true

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Google API (for LLM/AI features)
GOOGLE_API_KEY=your-api-key-here

# ============================================================================
# LOGGING
# ============================================================================
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# DEPLOYMENT-SPECIFIC (Docker/Production)
# ============================================================================
# Database host (for Docker Compose)
# DB_HOST=db
# DB_PORT=5432
# DB_NAME=FYP
# DB_USER=postgres
# DB_PASSWORD=

# API Configuration
# API_HOST=0.0.0.0
# API_PORT=8000
# API_WORKERS=4
